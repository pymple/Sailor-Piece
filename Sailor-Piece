                BossCurrentIsland=GetBossIsland(nextName)
                Notify.new({Title="Next: "..GetBossDisplay(nextName),Content="On "..(BossCurrentIsland or "?"),Duration=3,Icon=ICON})
            else ExitBossMode(deadName) end
        else BossTPDone=true end
        return
    end
    local model=CheckBoss(BossTargetName)
    if model and IsAnosModel(BossTargetName) and model.Name~=BossTargetName then BossTargetName=model.Name end
    if not model then
        local deadName=BossTargetName
        BossKills=BossKills+1 Kills=Kills+1 RecordBossDeath(deadName)
        Notify.new({Title="KILLED: "..GetBossDisplay(deadName),Content="Total: "..BossKills,Duration=4,Icon=ICON})
        BossTargetName=nil BossTPDone=false ClearTgt() HoverPos=nil task.wait(0.15)
        local nextName=PickNextBossName()
        if nextName then
            BossTargetName=nextName
            local nextIsland=GetBossIsland(nextName)
            if nextIsland==BossCurrentIsland then BossTPDone=true
            else BossTPDone=false LastBossTP=0 BossCurrentIsland=nextIsland end
            Notify.new({Title="Next: "..GetBossDisplay(nextName),Content="On "..(nextIsland or "?"),Duration=3,Icon=ICON})
        else ExitBossMode(deadName) end
        return
    end
    local bossP=ModelPos(model)
    if not bossP then BossTPDone=false task.wait(0.3) return end
    CurTarget=model
    TweenTo(model)
    Attack(model)
    if F.AutoEquip and tick()-LastEquip>3 then LastEquip=tick() local eq=GetTool() if not eq or eq.Name:lower()=="combat" then EquipSword() end end
end
