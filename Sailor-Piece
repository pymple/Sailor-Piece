local function InteractSpawnCrystal(island)
    if not island or not Flags.AutoSpawn then return end
    local crystalName = "SpawnPointCrystal_" .. island.Portal
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc.Name == crystalName then
            local prompt = nil
            if desc:IsA("Model") then
                for _, child in ipairs(desc:GetDescendants()) do
                    if child:IsA("ProximityPrompt") then prompt = child break end
                end
            elseif desc:IsA("BasePart") then
                prompt = desc:FindFirstChildOfClass("ProximityPrompt")
                if not prompt and desc.Parent then
                    for _, child in ipairs(desc.Parent:GetDescendants()) do
                        if child:IsA("ProximityPrompt") then prompt = child break end
                    end
                end
            end
            if prompt then
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local crystalPos = nil
                if desc:IsA("BasePart") then crystalPos = desc.Position
                elseif desc:IsA("Model") then
                    local primary = desc.PrimaryPart or desc:FindFirstChildWhichIsA("BasePart")
                    if primary then crystalPos = primary.Position end
                end
                if hrp and crystalPos then
                    if (hrp.Position - crystalPos).Magnitude > 15 then
                        hrp.CFrame = CFrame.new(crystalPos + Vector3.new(0, 3, 3))
                        task.wait(0.3)
                    end
                    pcall(function() fireproximityprompt(prompt) end)
                    task.wait(0.3)
                    pcall(function() fireproximityprompt(prompt) end)
                end
                return
            end
        end
    end
end

-- ==================== BOSS SCANNING ====================

local function IsKnownBoss(name)
    return BossToIsland[name] ~= nil
end

local function IsBossEnabled(name)
    return BossFlags[name] == true
end

local function FindAliveBosses()
    local npcsFolder = workspace:FindFirstChild("NPCs")
    if not npcsFolder then return {} end
    local bosses = {}
    for _, model in ipairs(npcsFolder:GetChildren()) do
        if model:IsA("Model") and IsKnownBoss(model.Name) and IsBossEnabled(model.Name) then
            local hum = model:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                table.insert(bosses, model)
            end
        end
    end
    return bosses
end

-- Get ALL bosses (enabled or not) for the info display
local function GetAllBossStatus()
    local npcsFolder = workspace:FindFirstChild("NPCs")
    local status = {}
    for _, bDef in ipairs(AllBosses) do
        local entry = {Name = bDef.Name, Island = bDef.Island, Enabled = BossFlags[bDef.Name], Alive = false, HP = 0, MaxHP = 0}
        if npcsFolder then
            for _, model in ipairs(npcsFolder:GetChildren()) do
                if model.Name == bDef.Name then
                    local hum = model:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health > 0 then
                        entry.Alive = true
                        entry.HP = math.floor(hum.Health)
                        entry.MaxHP = math.floor(hum.MaxHealth)
                    end
                    break
                end
            end
        end
        table.insert(status, entry)
    end
    return status
end

local function BuildBossInfoText()
    local statuses = GetAllBossStatus()
    local lines = {}
    for _, s in ipairs(statuses) do
        local icon = s.Alive and "🟢" or "⚫"
        local check = s.Enabled and "✅" or "❌"
        local hpText = s.Alive and (" HP:" .. s.HP) or ""
        table.insert(lines, icon .. " " .. check .. " " .. s.Name .. " (" .. s.Island .. ")" .. hpText)
    end
    return table.concat(lines, "\n")
end

-- ==================== ENEMY FINDING ====================

local function ShouldIgnore(name)
    local lower = name:lower()
    for _, ignore in ipairs(IgnoreNPCs) do
        if lower:find(ignore, 1, true) then return true end
    end
    return false
end

local function IsPlayerChar(model)
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character == model then return true end
    end
    return false
end

local function MatchesEnemyName(modelName, island)
    if not island then return false end
    local lower = modelName:lower()
    for _, enemyBase in ipairs(island.Enemies) do
        if lower:find(enemyBase:lower(), 1, true) then return true end
    end
    return false
end

local function FindEnemies(island)
    local npcsFolder = workspace:FindFirstChild("NPCs")
    if not npcsFolder or not island then return {} end
    local enemies = {}
    for _, model in ipairs(npcsFolder:GetChildren()) do
        if model:IsA("Model") and not IsPlayerChar(model) and not IsKnownBoss(model.Name) then
            local hum = model:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and not ShouldIgnore(model.Name) then
                if MatchesEnemyName(model.Name, island) then
                    table.insert(enemies, model)
                end
            end
        end
    end
    return enemies
end

local function GetNearest(enemies)
    local char = LocalPlayer.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local best, bestD = nil, math.huge
    for _, e in ipairs(enemies) do
        local root = e:FindFirstChild("HumanoidRootPart") or e:FindFirstChild("Torso") or e:FindFirstChild("UpperTorso")
        if root then
            local d = (root.Position - hrp.Position).Magnitude
            if d < bestD then bestD, best = d, e end
        end
    end
    return best
end

