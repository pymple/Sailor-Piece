local MoveM={}
function MoveM.TweenAbove(enemy)
    if not enemy then return end
    local r=Util.Root(enemy)
    if not r then return end
    local c=LP.Character
    if not c then return end
    local hrp=c:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local p=r.Position
    local ap=Vector3.new(p.X,p.Y+F.HeightOffset,p.Z)
    local d=(hrp.Position-ap).Magnitude
    if d<5 then LockTarget=enemy TweenOn=false HoverPos=ap return end
    StopTw()
    TweenOn=true
    LockTarget=nil
    LockA=0
    local cf=CFrame.new(ap,p)
    local sp=math.max(F.TweenSpeed,20)
    local dur=math.clamp(d/sp,0.05,6)
    ATween=TweenService:Create(hrp,TweenInfo.new(dur,Enum.EasingStyle.Linear),{CFrame=cf})
    ATween.Completed:Connect(function() ATween=nil TweenOn=false LockTarget=enemy HoverPos=ap end)
    ATween:Play()
    local t=tick()
    while TweenOn and tick()-t<dur+0.5 do task.wait(0.05) end
end
