function BossM.RecordDeath(name) BossDeathTimes[name]=tick() end
function BossM.GetStatus()
    local nf=workspace:FindFirstChild("NPCs")
    local out={}
    for _,bd in ipairs(Bosses) do
        local e={Name=bd.Name,Island=bd.Island,On=BF[bd.Name],Alive=false,HP=0,MHP=0,Timer=nil}
        if nf then
            for _,m in ipairs(nf:GetChildren()) do
                if m.Name==bd.Name then
                    local hm=m:FindFirstChildOfClass("Humanoid")
                    if hm and hm.Health>0 then
                        e.Alive=true
                        e.HP=math.floor(hm.Health)
                        e.MHP=math.floor(hm.MaxHealth)
                    end
                    break
                end
            end
        end
        if not e.Alive and BossDeathTimes[bd.Name] then
            local elapsed=tick()-BossDeathTimes[bd.Name]
            local respawn=300
            local remain=math.max(0,respawn-elapsed)
            if remain>0 then
                local mn=math.floor(remain/60)
                local sc=math.floor(remain%60)
                e.Timer=string.format("%dm%02ds",mn,sc)
            else
                e.Timer="Soon"
            end
        end
        table.insert(out,e)
    end
    return out
end
function BossM.InfoText()
