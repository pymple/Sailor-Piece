})

FarmSection:AddButton({
    Name = "Force Abandon Quest",
    Callback = function()
        FireQuestAbandon()
        Notifier.new({Title = "Quest", Content = "Abandoned", Duration = 2, Icon = AVATAR_ICON})
    end
})

FarmSection:AddButton({
    Name = "Scan Enemies",
    Callback = function()
        local island = CurrentIsland or GetIslandForLevel(GetPlayerLevel())
        local enemies = FindEnemies(island)
        local npcsFolder = workspace:FindFirstChild("NPCs")
        local allNames = {}
        if npcsFolder then
            local counts = {}
            for _, m in ipairs(npcsFolder:GetChildren()) do
                if m:IsA("Model") then counts[m.Name] = (counts[m.Name] or 0) + 1 end
            end
            for name, count in pairs(counts) do table.insert(allNames, name.." x"..count) end
            table.sort(allNames)
        end
        Notifier.new({
            Title = "Matched: "..#enemies.." ("..island.Portal..")",
            Content = "All NPCs:\n"..table.concat(allNames, "\n"),
            Duration = 15, Icon = AVATAR_ICON
        })
    end
})

