end

-- ==================== MOVEMENT ====================

local function GetEnemyRoot(enemy)
    if not enemy then return nil end
    return enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Torso") or enemy:FindFirstChild("UpperTorso")
end

local function TweenAboveEnemy(enemy)
    if not enemy then return end
    local root = GetEnemyRoot(enemy)
    if not root then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local pos = root.Position
    local abovePos = Vector3.new(pos.X, pos.Y + Flags.HeightOffset, pos.Z)
    local dist = (hrp.Position - abovePos).Magnitude

    if dist < 5 then
        LockedAboveTarget = enemy
        TweenActive = false
        return
    end

    StopTween()
    TweenActive = true
    LockedAboveTarget = nil
    LockAlpha = 0

    local targetCF = CFrame.new(abovePos, pos)
    local speed = math.max(Flags.TweenSpeed, 20)
    local duration = math.clamp(dist / speed, 0.05, 6)
    ActiveTween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCF})

    ActiveTween.Completed:Connect(function()
        ActiveTween = nil
        TweenActive = false
        LockedAboveTarget = enemy
    end)

    ActiveTween:Play()

    local t = tick()
    while TweenActive and tick() - t < duration + 0.5 do
        task.wait(0.05)
    end
end

