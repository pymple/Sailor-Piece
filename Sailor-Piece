local function RecordBossDeath(name) BossDeathTimes[name]=tick() end
local function GetBossStatus()
    local nf=workspace:FindFirstChild("NPCs")
    local out={}
    for _,bd in ipairs(Bosses) do
        local e={Name=bd.Name,Island=bd.Island or GetBossIsland(bd.Name) or "?",On=BF[bd.Name],Alive=false,HP=0,MHP=0,Timer=nil}
        if nf then
            for _,m in ipairs(nf:GetChildren()) do
                if m.Name==bd.Name then
                    local hm=m:FindFirstChildOfClass("Humanoid")
                    if hm and hm.Health>0 then
                        e.Alive=true
                        e.HP=math.floor(hm.Health)
                        e.MHP=math.floor(hm.MaxHealth)
                    end
                    break
                end
            end
        end
        if not e.Alive and BossDeathTimes[bd.Name] then
            local remain=math.max(0,300-(tick()-BossDeathTimes[bd.Name]))
            if remain>0 then e.Timer=string.format("%dm%02ds",math.floor(remain/60),math.floor(remain%60))
            else e.Timer="Soon" end
        end
        table.insert(out,e)
    end
    return out
end
local function BossInfoText()
    local st=GetBossStatus()
    local lines={}
    for _,s in ipairs(st) do
        local state=""
        if s.Alive then state="ALIVE HP:"..s.HP.."/"..s.MHP
        elseif s.Timer then state="Respawn: "..s.Timer
        else state="Dead" end
        table.insert(lines,s.Name.." ("..s.Island..") - "..state)
    end
    return table.concat(lines,"\n")
end
