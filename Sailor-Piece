local function ScanAllBossTimers()
    local results={}
    local nf=workspace:FindFirstChild("NPCs")
    if not nf then return results end
    for _,bDef in ipairs(Bosses) do
        for _,m in ipairs(nf:GetChildren()) do
            if m:IsA("Model") and m.Name==bDef.Name then
                local hm=m:FindFirstChildOfClass("Humanoid")
                if hm and hm.Health>0 then
                    results[bDef.Name]={alive=true,hp=math.floor(hm.Health),mhp=math.floor(hm.MaxHealth)}
                else
                    for _,d in ipairs(m:GetDescendants()) do
                        if d:IsA("TextLabel") then
                            local mn,sc=(d.Text or ""):match("(%d+):(%d+)")
                            if mn and sc then
                                results[bDef.Name]={m=tonumber(mn),s=tonumber(sc)}
                                break
                            end
                        end
                    end
                    if not results[bDef.Name] then
                        for _,d in ipairs(m:GetDescendants()) do
                            if d:IsA("BillboardGui") then
                                for _,child in ipairs(d:GetDescendants()) do
                                    if child:IsA("TextLabel") then
                                        local mn,sc=(child.Text or ""):match("(%d+):(%d+)")
                                        if mn and sc then
                                            results[bDef.Name]={m=tonumber(mn),s=tonumber(sc)}
                                            break
                                        end
                                    end
                                end
                                if results[bDef.Name] then break end
                            end
                        end
                    end
                end
                break
            end
        end
    end
    local pg=LP:FindFirstChild("PlayerGui")
    if pg then
        for _,desc in ipairs(pg:GetDescendants()) do
            if desc:IsA("TextLabel") then
                local txt=desc.Text or ""
                for _,bDef in ipairs(Bosses) do
                    if not results[bDef.Name] then
                        local short=bDef.Display or bDef.Name:gsub("Boss","")
                        if txt:find(short) then
                            local mn,sc=txt:match("(%d+):(%d+)")
                            if mn and sc then
                                results[bDef.Name]={m=tonumber(mn),s=tonumber(sc)}
                            end
                        end
                    end
                end
            end
        end
    end
    for k,v in pairs(results) do BossTimerCache[k]=v BossTimerCache[k].t=tick() end
    return results
end
local function GetBossTimerText()
    local lines={}
    for _,bDef in ipairs(Bosses) do
        local d=bDef.Display or bDef.Name:gsub("Boss","")
        local info=BossTimerCache[bDef.Name]
        local status=""
        if info and(tick()-(info.t or 0))<5 then
            if info.alive then
                local hp=info.hp or 0
                local mhp=info.mhp or 0
                status="⚔ ALIVE "..hp.."/"..mhp
            elseif info.m and info.s then
                local total=info.m*60+info.s
                if total==0 then
                    status="⚔ ALIVE"
                elseif total<=15 then
                    status="🟢 "..info.m..":"..string.format("%02d",info.s).." SPAWNING!"
                elseif total<=60 then
                    status="🟡 "..info.m..":"..string.format("%02d",info.s)
                else
                    status="🔴 "..info.m..":"..string.format("%02d",info.s)
                end
            else
                status="⏳ Loading..."
            end
        else
            local dt=BossDeathTimes[bDef.Name]
            if dt then
                local remain=math.max(0,300-(tick()-dt))
                if remain>0 then
                    local mn=math.floor(remain/60)
                    local sc=math.floor(remain%60)
                    local total=mn*60+sc
                    if total<=15 then status="🟢 "..mn..":"..string.format("%02d",sc).." SPAWNING!"
                    elseif total<=60 then status="🟡 "..mn..":"..string.format("%02d",sc)
                    else status="🔴 "..mn..":"..string.format("%02d",sc) end
                else
                    status="🟢 Ready!"
                end
            else
                status="⏳ Loading..."
            end
        end
        table.insert(lines,d.." ("..bDef.Island..") - "..status)
    end
    return table.concat(lines,"\n")
end
