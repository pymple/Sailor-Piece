-- ==================== MAIN LOOP — SIMPLE AND ROBUST ====================

task.spawn(function()
    while ClockRunning do
        if not Flags.AutoFarmLevel then
            task.wait(0.5)
            continue
        end

        if not IsCharacterAlive() then
            StopTween()
            CurrentTarget = nil
            WaitForCharacter()
            task.wait(1)
            if Flags.AutoEquip then EquipSword() task.wait(0.3) end
        end

        if not IsCharacterAlive() then task.wait(1) continue end

        local playerLevel = GetPlayerLevel()
        if playerLevel == 0 then task.wait(1) continue end

        local targetIsland
        if Flags.SelectedIsland == "Auto" then
            targetIsland = GetIslandForLevel(playerLevel)
        else
            targetIsland = GetIslandByName(Flags.SelectedIsland) or GetIslandForLevel(playerLevel)
        end

        -- Island changed
        if not CurrentIsland or CurrentIsland.Portal ~= targetIsland.Portal then
            if CurrentIsland then StopTween() AbandonQuest() task.wait(0.5) end
            CurrentIsland = targetIsland
            IslandTeleported = false
            QuestAccepted = false
            CurrentTarget = nil
            LastEnemySeenTime = 0
            PrevQuestStatus = nil
            Notifier.new({Title = "-> "..targetIsland.Portal, Content = "Lv."..playerLevel.." | Quest "..targetIsland.QuestNum, Duration = 4, Icon = AVATAR_ICON})
        end

        -- Teleport to island
        if not IslandTeleported then
            if CanTeleport() and TeleportToIsland(CurrentIsland.Portal) then
                IslandTeleported = true
                task.wait(2)
                WaitForEnemies(CurrentIsland, 6)
                LastEnemySeenTime = tick()
                if Flags.AutoSpawn then task.wait(0.5) SetIslandSpawn(CurrentIsland) end
                if Flags.AutoQuest and not QuestAccepted then
                    task.wait(0.5)
                    AcceptQuest(CurrentIsland)
                    QuestAccepted = true
                end
            else
                task.wait(3)
            end
            continue
        end

        -- Accept quest if not yet
        if not QuestAccepted and Flags.AutoQuest then
            AcceptQuest(CurrentIsland)
            QuestAccepted = true
        end

        -- Smart quest re-accept: watch for completion
        if Flags.AutoQuest and QuestAccepted then
            local complete = IsQuestComplete()
            if complete then
                task.wait(Jitter(0.5, 0.2))
                SmartQuestCycle(CurrentIsland)
                QuestAccepted = true
            end
        end

        -- Find and fight enemies
        local enemies = FindEnemies(CurrentIsland)

        if #enemies > 0 then
            LastEnemySeenTime = tick()

            -- Validate current target
            if CurrentTarget then
                local hum = CurrentTarget:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health <= 0 or not CurrentTarget.Parent or not MatchesEnemyName(CurrentTarget.Name, CurrentIsland) then
                    if hum and hum.Health <= 0 then KillCount = KillCount + 1 end
                    CurrentTarget = nil
                end
            end

            -- Pick new target
            if not CurrentTarget then
                enemies = FindEnemies(CurrentIsland)
                CurrentTarget = GetNearest(enemies)
            end

            -- Tween above and attack
            if CurrentTarget then
                TweenAboveEnemy(CurrentTarget)
                Attack(CurrentTarget)
            end
        else
            CurrentTarget = nil
            if tick() - LastEnemySeenTime > 45 and CanTeleport() then
                IslandTeleported = false
                QuestAccepted = false
                LastEnemySeenTime = 0
            end
            task.wait(0.3)
        end

        -- Auto equip check
        if Flags.AutoEquip and tick() - LastEquipCheck > 4 then
            LastEquipCheck = tick()
            local eq = GetEquippedTool()
            if not eq or eq.Name:lower() == "combat" then EquipSword() end
        end

        task.wait(0.15)
    end
end)
