local function CanTeleport()
    if tick() - LastTeleportTime < 10 then return false end
    if tick() - LastTeleportReset > 120 then
        TeleportCount = 0
        LastTeleportReset = tick()
    end
    if TeleportCount >= 3 then return false end
    return true
end

local function TeleportToIsland(portal)
    if not CanTeleport() then return false end
    LastTeleportTime = tick()
    TeleportCount = TeleportCount + 1
    local success = false
    pcall(function()
        ReplicatedStorage:WaitForChild("Remotes",5):WaitForChild("TeleportToPortal",5):FireServer(portal)
        success = true
    end)
    return success
end

local function FindQuestRemote(remoteName)
    local paths = {
        {"RemoteEvents", remoteName},
        {"Remotes", remoteName},
        {"Events", remoteName},
        {"CombatSystem", "Remotes", remoteName},
    }
    for _, path in ipairs(paths) do
        local current = ReplicatedStorage
        local found = true
        for _, segment in ipairs(path) do
            current = current:FindFirstChild(segment)
            if not current then found = false break end
        end
        if found then return current end
    end
    for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
        if desc:IsA("RemoteEvent") and desc.Name == remoteName then
            return desc
        end
    end
    return nil
end

local function AcceptQuests(list)
    if tick() - LastQuestTime < 2 then return end
    LastQuestTime = tick()
    for _, q in ipairs(list) do
        task.wait(Jitter(0.15, 0.05))
        pcall(function()
            local remote = FindQuestRemote("QuestAccept")
            if remote then remote:FireServer(q) end
        end)
        pcall(function()
            local remote = FindQuestRemote("AcceptQuest")
            if remote then remote:FireServer(q) end
        end)
        pcall(function()
            local remote = FindQuestRemote("StartQuest")
            if remote then remote:FireServer(q) end
        end)
    end
end

local function AbandonQuest()
    pcall(function()
        local remote = FindQuestRemote("QuestAbandon") or FindQuestRemote("AbandonQuest")
        if remote then remote:FireServer("repeatable") end
    end)
end

local function SmartQuestCycle()
    if not CurrentIsland or not CurrentIsland.Quest then return end
    AbandonQuest()
    task.wait(Jitter(0.4, 0.15))
    LastQuestTime = 0
    AcceptQuests(CurrentIsland.Quest)
    QuestKillCount = 0
    LastQuestReaccept = tick()
end

local function ShouldIgnore(name)
    local lower = name:lower()
    for _, ignore in ipairs(IgnoreNPCs) do
        if lower:find(ignore, 1, true) then return true end
    end
    return false
end

local function IsBoss(name)
    local lower = name:lower()
    for _, kw in ipairs(BossKeywords) do
        if lower:find(kw, 1, true) then return true end
    end
    return false
end

local function IsPlayerChar(model)
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character == model then return true end
    end
    return false
end

local function MatchesEnemyName(modelName, island)
    if not island then return true end
    local lower = modelName:lower()
    for _, enemyBase in ipairs(island.Enemies) do
        if lower:find(enemyBase:lower(), 1, true) then return true end
    end
    return false
end

local function FindEnemies(island)
    if tick() - CacheTime < CACHE_TTL and #CachedEnemies > 0 then
        local alive = {}
        for _, e in ipairs(CachedEnemies) do
            local hum = e:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and e.Parent then
                table.insert(alive, e)
            end
        end
        if #alive > 0 then
            CachedEnemies = alive
            return alive
        end
    end

    local enemies = {}
    local npcsFolder = workspace:FindFirstChild("NPCs")
    if not npcsFolder then return enemies end

    for _, model in ipairs(npcsFolder:GetChildren()) do
        if model:IsA("Model") and not IsPlayerChar(model) then
            local hum = model:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and not IsBoss(model.Name) and not ShouldIgnore(model.Name) then
                if not island or MatchesEnemyName(model.Name, island) then
                    table.insert(enemies, model)
                end
            end
        end
    end

    if #enemies == 0 and island then
        for _, model in ipairs(npcsFolder:GetChildren()) do
            if model:IsA("Model") and not IsPlayerChar(model) then
                local hum = model:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 and not IsBoss(model.Name) and not ShouldIgnore(model.Name) then
                    table.insert(enemies, model)
                end
            end
        end
    end

    CachedEnemies = enemies
    CacheTime = tick()
    return enemies
end

local function WaitForEnemies(island, maxWait)
    local start = tick()
    while tick() - start < maxWait do
        local enemies = FindEnemies(island)
        if #enemies > 0 then return enemies end
        CachedEnemies = {}
        CacheTime = 0
        task.wait(0.3)
    end
    return {}
end

local function GetNearest(enemies)
    local char = LocalPlayer.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local best, bestD = nil, math.huge
    for _, e in ipairs(enemies) do
        local root = e:FindFirstChild("HumanoidRootPart") or e:FindFirstChild("Torso") or e:FindFirstChild("UpperTorso")
        if root then
            local d = (root.Position - hrp.Position).Magnitude
            if d < bestD then bestD, best = d, e end
        end
    end
    return best
end

