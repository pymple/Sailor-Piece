        Flag = "Boss_" .. bDef.Name,
        Default = false,
        Callback = function(v) BossFlags[bDef.Name] = v end
    })
end

-- Boss status info (updates every 2 seconds)
BossInfoParagraph = BossSection:AddParagraph({
    Title = "Boss Status",
    Content = "Loading..."
})

-- Update boss info paragraph periodically
task.spawn(function()
    while ClockRunning do
        task.wait(2)
        if BossInfoParagraph then
            pcall(function()
                local text = BuildBossInfoText()
                if BossInfoParagraph.SetContent then
                    BossInfoParagraph:SetContent(text)
                elseif BossInfoParagraph.Set then
                    BossInfoParagraph:Set(text)
                elseif BossInfoParagraph.SetText then
                    BossInfoParagraph:SetText(text)
                end
            end)
        end
    end
end)

BossSection:AddButton({
    Name = "Scan Bosses Now",
    Callback = function()
        local statuses = GetAllBossStatus()
        local lines = {}
        for _, s in ipairs(statuses) do
            local alive = s.Alive and ("ALIVE HP:" .. s.HP .. "/" .. s.MaxHP) or "DEAD"
            local enabled = s.Enabled and "[ON]" or "[OFF]"
            table.insert(lines, enabled .. " " .. s.Name .. " (" .. s.Island .. ") - " .. alive)
        end
        Notifier.new({
            Title = "All Boss Status",
            Content = table.concat(lines, "\n"),
            Duration = 12, Icon = AVATAR_ICON
        })
    end
})

