local function FireAbilities()
    if tick() - LastSkillTime < Flags.SkillCooldown then return end
    local any = Flags.SkillZ or Flags.SkillX or Flags.SkillC or Flags.SkillV or Flags.SkillB
    if not any then return end
    LastSkillTime = tick()
    pcall(function()
        local r = ReplicatedStorage:WaitForChild("AbilitySystem", 2):WaitForChild("Remotes", 2):WaitForChild("RequestAbility", 2)
        if Flags.SkillZ then pcall(function() r:FireServer(1) end) end
        if Flags.SkillX then pcall(function() r:FireServer(2) end) end
        if Flags.SkillC then pcall(function() r:FireServer(3) end) end
        if Flags.SkillV then pcall(function() r:FireServer(4) end) end
        if Flags.SkillB then pcall(function() r:FireServer(5) end) end
    end)
end

local function Attack(target)
    local targetRoot = target and GetEnemyRoot(target)
    pcall(function()
        ReplicatedStorage:WaitForChild("CombatSystem", 2):WaitForChild("Remotes", 2):WaitForChild("RequestHit", 2):FireServer(target)
    end)
    local tool = GetEquippedTool()
    if tool then
        pcall(function() tool:Activate() end)
        if target and targetRoot then
            local handle = tool:FindFirstChild("Handle")
            if handle then
                pcall(function()
                    firetouchinterest(handle, targetRoot, 0)
                    task.delay(0.06, function() pcall(function() firetouchinterest(handle, targetRoot, 1) end) end)
                end)
            end
        end
    end
    FireAbilities()
end

