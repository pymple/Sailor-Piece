local function DoBossTick()
    if not BossTargetName then
        local nextName=PickNextBossName()
        if nextName then
            BossTargetName=nextName BossTPDone=false LastBossTP=0 ClearTgt() HoverPos=nil
            BossCurrentIsland=GetBossIsland(nextName)
            Notify.new({Title="Next: "..GetBossDisplay(nextName),Content="On "..(BossCurrentIsland or "?"),Duration=3,Icon=ICON})
        else ExitBossMode(nil) end
        return
    end
    if not BossTPDone then
        local bi=GetBossIsland(BossTargetName)
        if not bi then BossTargetName=nil return end
        local model=CheckBoss(BossTargetName)
        if model then
            local bp=ModelPos(model)
            if bp and DistTo(bp)<300 then BossTPDone=true BossCurrentIsland=bi return end
        end
        if tick()-LastBossTP<4 then task.wait(0.2) return end
        ClearTgt() HoverPos=nil LastBossTP=tick()
        Notify.new({Title="TP -> "..bi,Content=GetBossDisplay(BossTargetName),Duration=2,Icon=ICON})
        ForceTP(bi)
        task.wait(1.5)
        BossCurrentIsland=bi
        local renderPos=GetRenderPos(BossTargetName)
        if renderPos then
            local hrp=PlayerHRP()
            if hrp then hrp.CFrame=CFrame.new(renderPos.X,renderPos.Y+F.HeightOffset,renderPos.Z) end
            task.wait(0.5)
        else
            local hrp=PlayerHRP()
            if hrp then TweenToPoint(hrp.Position+Vector3.new(150,F.HeightOffset,150)) task.wait(0.3) end
        end
        for _=1,10 do
            local m=CheckBoss(BossTargetName)
            if m and ModelPos(m) then BossTPDone=true return end
            task.wait(0.3)
        end
        if not renderPos then
            local hrp=PlayerHRP()
            if hrp then TweenToPoint(hrp.Position+Vector3.new(-300,F.HeightOffset,-300)) task.wait(0.3) end
            for _=1,6 do
                local m=CheckBoss(BossTargetName)
                if m and ModelPos(m) then BossTPDone=true return end
                task.wait(0.3)
            end
        end
        local m3=CheckBoss(BossTargetName)
        if not m3 then
            local deadName=BossTargetName
            BossKills=BossKills+1 Kills=Kills+1 RecordBossDeath(deadName)
            Notify.new({Title="KILLED: "..GetBossDisplay(deadName),Content="Total: "..BossKills,Duration=4,Icon=ICON})
            BossTargetName=nil BossTPDone=false ClearTgt() HoverPos=nil task.wait(0.15)
            local nextName=PickNextBossName()
            if nextName then
