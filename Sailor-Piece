-- ==================== MAIN LOOP ====================

task.spawn(function()
    while ClockRunning do
        if not Flags.AutoFarmLevel then task.wait(0.5) continue end

        -- Death recovery
        if not IsCharacterAlive() then
            StopTween()
            CurrentTarget = nil
            WaitForCharacter()
            task.wait(0.5)
            if Flags.AutoEquip then EquipSword() task.wait(0.3) end
        end
        if not IsCharacterAlive() then task.wait(0.5) continue end

        -- Get level and island
        local playerLevel = GetPlayerLevel()
        if playerLevel == 0 then task.wait(0.5) continue end

        local targetIsland
        if Flags.SelectedIsland == "Auto" then
            targetIsland = GetIslandForLevel(playerLevel)
        else
            targetIsland = GetIslandByName(Flags.SelectedIsland) or GetIslandForLevel(playerLevel)
        end

        -- Island changed
        if not CurrentIsland or CurrentIsland.Portal ~= targetIsland.Portal then
            if CurrentIsland then StopTween() AbandonQuest() task.wait(0.3) end
            CurrentIsland = targetIsland
            IslandTeleported = false
            QuestAccepted = false
            CurrentTarget = nil
            LastEnemySeenTime = 0
            Notifier.new({Title = "-> "..targetIsland.Portal, Content = "Lv."..playerLevel.." | Quest "..targetIsland.QuestNum, Duration = 3, Icon = AVATAR_ICON})
        end

        -- Teleport to island if needed
        if not IslandTeleported then
            if TeleportToIsland(CurrentIsland.Portal) then
                IslandTeleported = true
                task.wait(1.5)
                -- Quick scan for enemies
                for _ = 1, 10 do
                    if #FindEnemies(CurrentIsland) > 0 then break end
                    task.wait(0.3)
                end
                LastEnemySeenTime = tick()
                if Flags.AutoSpawn then SetIslandSpawn(CurrentIsland) end
                if Flags.AutoQuest and not QuestAccepted then
                    AcceptQuest(CurrentIsland)
                    QuestAccepted = true
                end
            else
                task.wait(2)
            end
            continue
        end

        -- Quest management
        if not QuestAccepted and Flags.AutoQuest then
            AcceptQuest(CurrentIsland)
            QuestAccepted = true
        end
        if Flags.AutoQuest and QuestAccepted and IsQuestComplete() then
            SmartQuestCycle(CurrentIsland)
            QuestAccepted = true
        end

        -- Find and fight
        local enemies = FindEnemies(CurrentIsland)
        if #enemies > 0 then
            LastEnemySeenTime = tick()

            if CurrentTarget then
                local hum = CurrentTarget:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health <= 0 or not CurrentTarget.Parent or not MatchesEnemyName(CurrentTarget.Name, CurrentIsland) then
                    if hum and hum.Health <= 0 then KillCount = KillCount + 1 end
                    CurrentTarget = nil
                end
            end

            if not CurrentTarget then
                CurrentTarget = GetNearest(FindEnemies(CurrentIsland))
            end

            if CurrentTarget then
                TweenAboveEnemy(CurrentTarget)
                Attack(CurrentTarget)
            end
        else
            CurrentTarget = nil
            if tick() - LastEnemySeenTime > 30 then
                IslandTeleported = false
                QuestAccepted = false
                LastEnemySeenTime = 0
            end
            task.wait(0.2)
        end

        -- Auto equip
        if Flags.AutoEquip and tick() - LastEquipCheck > 4 then
            LastEquipCheck = tick()
            local eq = GetEquippedTool()
            if not eq or eq.Name:lower() == "combat" then EquipSword() end
        end

        task.wait(0.12)
    end
end)
