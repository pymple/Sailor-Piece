-- ==================== QUEST SYSTEM ====================
-- Find the EXACT quest remote. It's under Remotes somewhere (same parent as ShopRemotes, EventRemotes, etc.)
-- We look for a remote specifically named for quests, excluding shops/events/dungeons/boosts/titles

local QuestBlacklist = {"shop", "boost", "title", "event", "dungeon", "raid", "getboost", "gettitle", "getevent", "teleport", "combat", "ability", "spawn", "checkpoint"}

local function IsBlacklisted(fullName)
    local lower = fullName:lower()
    for _, bl in ipairs(QuestBlacklist) do
        if lower:find(bl, 1, true) then return true end
    end
    return false
end

local function FindQuestRemote()
    if QuestRemote then return QuestRemote end
    if QuestRemoteSearched then return nil end

    -- Strategy 1: Look under Remotes folder specifically
    local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
    if remotesFolder then
        -- Direct children first
        for _, child in ipairs(remotesFolder:GetChildren()) do
            if (child:IsA("RemoteEvent") or child:IsA("RemoteFunction")) then
                local n = child.Name:lower()
                if n:find("quest") and not IsBlacklisted(child:GetFullName()) then
                    QuestRemote = child
                    QuestRemoteSearched = true
                    return child
                end
            end
        end
        -- Then go one level deeper (subfolder like QuestRemotes)
        for _, subfolder in ipairs(remotesFolder:GetChildren()) do
            if subfolder:IsA("Folder") or subfolder:IsA("Configuration") then
                local n = subfolder.Name:lower()
                if n:find("quest") then
                    for _, child in ipairs(subfolder:GetChildren()) do
                        if (child:IsA("RemoteEvent") or child:IsA("RemoteFunction")) then
                            local cn = child.Name:lower()
                            if cn:find("accept") or cn:find("start") or cn:find("begin") or cn:find("quest") then
                                QuestRemote = child
                                QuestRemoteSearched = true
                                return child
                            end
                        end
                    end
                    -- If only one remote in there, use it
                    local remotes = {}
                    for _, child in ipairs(subfolder:GetChildren()) do
                        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                            table.insert(remotes, child)
                        end
                    end
                    if #remotes == 1 then
                        QuestRemote = remotes[1]
                        QuestRemoteSearched = true
                        return remotes[1]
                    end
                end
            end
        end
    end

    -- Strategy 2: Broader search but very targeted
    for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
        if (desc:IsA("RemoteEvent") or desc:IsA("RemoteFunction")) then
            local n = desc.Name:lower()
            if (n == "acceptquest" or n == "startquest" or n == "questaccept" or n == "queststart" or n == "beginquest") then
                if not IsBlacklisted(desc:GetFullName()) then
                    QuestRemote = desc
                    QuestRemoteSearched = true
                    return desc
                end
            end
        end
    end

    QuestRemoteSearched = true
    return nil
end

local function AcceptQuest(island)
    if not island then return end
    if tick() - LastQuestAccept < 3 then return end
    LastQuestAccept = tick()

    local remote = FindQuestRemote()
    if remote then
        if remote:IsA("RemoteEvent") then
            pcall(function() remote:FireServer(island.QuestNum) end)
            pcall(function() remote:FireServer(tostring(island.QuestNum)) end)
        elseif remote:IsA("RemoteFunction") then
            pcall(function() remote:InvokeServer(island.QuestNum) end)
            pcall(function() remote:InvokeServer(tostring(island.QuestNum)) end)
        end
        return
    end

    -- Fallback: fire proximity prompt on quest NPC
    local npcsFolder = workspace:FindFirstChild("NPCs")
    if npcsFolder then
        for _, npc in ipairs(npcsFolder:GetChildren()) do
            if npc:IsA("Model") and npc.Name:lower():find("quest") then
                for _, desc in ipairs(npc:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") then
                        pcall(function() fireproximityprompt(desc) end)
                        task.wait(0.2)
                        pcall(function() fireproximityprompt(desc) end)
                        return
                    end
                end
            end
        end
    end
end

local function AbandonQuest()
    local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
    if remotesFolder then
        for _, desc in ipairs(remotesFolder:GetDescendants()) do
            if desc:IsA("RemoteEvent") then
                local n = desc.Name:lower()
                if n:find("abandon") or n:find("cancel") or n:find("quit") then
                    pcall(function() desc:FireServer() end)
                    return
                end
            end
        end
    end
    for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
        if desc:IsA("RemoteEvent") then
            local n = desc.Name:lower()
            if n == "abandonquest" or n == "questcancel" or n == "questquit" then
                pcall(function() desc:FireServer() end)
                return
            end
        end
    end
end

