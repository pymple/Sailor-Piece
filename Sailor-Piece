-- ==================== SMOOTH LOCK ABOVE (no vibration) ====================

AddConnection(RunService.Stepped:Connect(function(_, dt)
    if not Flags.AutoFarmLevel then return end
    if TweenActive then LockAlpha = 0 return end
    if not LockedAboveTarget then LockAlpha = 0 return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Validate target
    local hum = LockedAboveTarget:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 or not LockedAboveTarget.Parent then
        LockedAboveTarget = nil
        LockAlpha = 0
        return
    end

    -- If normal enemy, validate island match
    if not FightingBoss and CurrentIsland then
        if not MatchesEnemyName(LockedAboveTarget.Name, CurrentIsland) and not IsKnownBoss(LockedAboveTarget.Name) then
            LockedAboveTarget = nil
            LockAlpha = 0
            return
        end
    end

    -- Noclip
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = false end
    end

    local root = GetEnemyRoot(LockedAboveTarget)
    if not root then return end

    local pos = root.Position
    local goalPos = Vector3.new(pos.X, pos.Y + Flags.HeightOffset, pos.Z)
    local goalCF = CFrame.new(goalPos, pos)

    -- Smooth ramp-up to avoid snap
    LockAlpha = math.min(LockAlpha + dt * 4, 1)
    local smoothAlpha = math.clamp(LockAlpha * 0.7, 0.05, 0.7)

    hrp.CFrame = hrp.CFrame:Lerp(goalCF, smoothAlpha)

    hrp.Velocity = Vector3.zero
    pcall(function() hrp.AssemblyLinearVelocity = Vector3.zero end)
    pcall(function() hrp.AssemblyAngularVelocity = Vector3.zero end)
end))

-- ==================== BOSS HELPERS ====================

local function SaveFarmState()
    if not FightingBoss and CurrentIsland then
        PreBossIslandPortal = CurrentIsland.Portal
        PreBossQuestState = QuestState
    end
end

local function RestoreFarmState()
    FightingBoss = false
    CurrentBossTarget = nil
    CurrentTarget = nil
    LockedAboveTarget = nil
    LockAlpha = 0

    if PreBossIslandPortal then
        local restoreIsland = GetIslandByName(PreBossIslandPortal)
        if restoreIsland then
            -- Check if we're already on the correct island (boss was on same island)
            if CurrentIsland and CurrentIsland.Portal == PreBossIslandPortal then
                -- Same island, just resume — no teleport needed
                IslandTeleported = true
                QuestState = PreBossQuestState
                -- Re-accept quest if it was active
                if Flags.AutoQuest and QuestState == "NONE" then
                    FireQuestAccept(CurrentIsland)
                end
            else
                -- Different island, need to teleport back
                CurrentIsland = restoreIsland
                IslandTeleported = false
                QuestState = "NONE"
                LastEnemySeenTime = 0
            end
        end
    end

    PreBossIslandPortal = nil
    PreBossQuestState = "NONE"
end

local function GetNextBoss()
    local bosses = FindAliveBosses()
    if #bosses == 0 then return nil end

    -- Prefer bosses closest to player
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        local closest, closestDist = nil, math.huge
        for _, boss in ipairs(bosses) do
            local root = GetEnemyRoot(boss)
            if root then
                local d = (root.Position - hrp.Position).Magnitude
                if d < closestDist then closestDist = d closest = boss end
            end
        end
        if closest then return closest end
    end

    return bosses[1]
end

