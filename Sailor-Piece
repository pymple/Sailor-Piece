local function AllBossesOnIsland(island)
    local nf=GetNPCFolder() if not nf then return {} end
    local out={}
    for _,m in ipairs(nf:GetChildren()) do
        if m:IsA("Model") then
            local hm=GetHum(m)
            if hm and hm.Health>0 then
                if AllBossNames[m.Name] and BF[m.Name] and BossIsland[m.Name]==island then table.insert(out,m.Name)
                elseif IsAnosModel(m.Name) and F.AnosEnabled and island==ANOS_ISLAND then table.insert(out,m.Name) end
