local function WaitForBossNearby(bossName,timeout)
    local t=tick()
    while tick()-t<(timeout or 10) do
        local fresh=FindBossModel(bossName)
        if fresh and DistTo(fresh)<500 then return fresh end
        task.wait(0.4)
    end
    return nil
end
local function DoFarmTick()
    local tgtIsland=GetFarmIsland()
    if not tgtIsland then return end
    if not CurIsland or CurIsland.Portal~=tgtIsland.Portal then
        if CurIsland then StopTw() QuestAbandon() task.wait(0.3) end
        CurIsland=tgtIsland
        IslandTPd=false
        SpawnDone=false
        QState="NONE"
        CurTarget=nil
        LockTarget=nil
        LockA=0
        HoverPos=nil
        LastEnemy=0
        LastQuestAccept=0
        QCompDet=false
        Notify.new({Title="-> "..tgtIsland.Portal,Content="Lv."..GetLevel().." | "..tgtIsland.QuestNPC,Duration=3,Icon=ICON})
    end
    if not IslandTPd then
        if DoTP(CurIsland.Portal) then
            IslandTPd=true
            task.wait(1.5)
            for _=1,10 do if #FindEnemies(CurIsland)>0 then break end task.wait(0.3) end
            LastEnemy=tick()
            if F.AutoSpawn and not SpawnDone then SpawnCrystal(CurIsland) SpawnDone=true task.wait(0.3) end
            if F.AutoQuest and QState=="NONE" then task.wait(0.2) QuestAccept(CurIsland) end
        else task.wait(2) end
        return
    end
    if F.AutoQuest then
        if QState=="NONE" then
            if tick()-LastQuestAccept>10 then QuestAccept(CurIsland) end
        elseif QState=="ACTIVE" then
            if QCompDet then
                QState="COOLDOWN"
                QCompDet=false
                task.wait(1.0)
                QState="NONE"
                QuestAccept(CurIsland)
            end
        end
    end
    local enemies=FindEnemies(CurIsland)
    if #enemies>0 then
        LastEnemy=tick()
        if CurTarget then
            local hm=CurTarget:FindFirstChildOfClass("Humanoid")
            if not hm or hm.Health<=0 or not CurTarget.Parent then
                if hm and hm.Health<=0 then Kills=Kills+1 end
                CurTarget=nil
                LockTarget=nil
                LockA=0
            elseif not MatchEnemy(CurTarget.Name,CurIsland) then
                CurTarget=nil
                LockTarget=nil
                LockA=0
            end
        end
        if not CurTarget then CurTarget=NearestFrom(FindEnemies(CurIsland)) end
        if CurTarget then
            TweenAbove(CurTarget)
            Attack(CurTarget)
        end
    else
        CurTarget=nil
        LockTarget=nil
        LockA=0
        if tick()-LastEnemy>30 then
            IslandTPd=false
            SpawnDone=false
            QState="NONE"
            LastEnemy=0
            QCompDet=false
            HoverPos=nil
        end
        task.wait(0.2)
    end
    if F.AutoEquip and tick()-LastEquip>4 then
        LastEquip=tick()
        local eq=GetTool()
        if not eq or eq.Name:lower()=="combat" then EquipSword() end
    end
end
local function DoBossTick()
    if not BossTarget or not BossAlive(BossTarget) then
        if BossTarget then
            BossKills=BossKills+1
            Kills=Kills+1
            RecordBossDeath(BossTarget.Name)
            local dn=BossDisplay[BossTarget.Name] or BossTarget.Name
            Notify.new({Title="KILLED: "..dn,Content="Total: "..BossKills,Duration=4,Icon=ICON})
        end
        BossTarget=nil
        ClearTgt()
        HoverPos=nil
        task.wait(0.5)
        local nb=GetNextBoss()
        if nb then
            BossTarget=nb
            BossPhase="TP"
            local dn=BossDisplay[nb.Name] or nb.Name
            Notify.new({Title="Next: "..dn,Content="On "..BossIsland[nb.Name],Duration=3,Icon=ICON})
        else
            BossFight=false
            BossPhase="IDLE"
            CurIsland=nil
            IslandTPd=false
            SpawnDone=false
            QState="NONE"
            LastQuestAccept=0
            QCompDet=false
            LastEnemy=0
            Notify.new({Title="All Bosses Clear!",Content="Returning to farming...",Duration=3,Icon=ICON})
        end
        return
    end
    if BossPhase=="TP" then
        local bi=BossIsland[BossTarget.Name]
        if not bi then BossPhase="FIGHT" return end
        if DistTo(BossTarget)<500 then BossPhase="FIGHT" return end
        local dn=BossDisplay[BossTarget.Name] or BossTarget.Name
        Notify.new({Title="Teleporting...",Content=bi.." for "..dn,Duration=2,Icon=ICON})
        if TeleportAndWait(bi,3) then
            local fresh=WaitForBossNearby(BossTarget.Name,12)
            if fresh then
                BossTarget=fresh
                BossPhase="FIGHT"
            else
                local stillAlive=FindBossModel(BossTarget.Name)
                if stillAlive then
                    BossTarget=stillAlive
                    if DistTo(BossTarget)<500 then BossPhase="FIGHT"
                    else task.wait(1) end
                else
                    RecordBossDeath(BossTarget.Name)
                    BossTarget=nil
                end
            end
        else
            task.wait(2)
        end
        return
    end
    if BossPhase=="FIGHT" then
        local fresh=FindBossModel(BossTarget.Name)
        if fresh then BossTarget=fresh end
        if not BossAlive(BossTarget) then return end
        if DistTo(BossTarget)>500 then BossPhase="TP" return end
        CurTarget=BossTarget
        TweenAbove(BossTarget)
        Attack(BossTarget)
        if F.AutoEquip and tick()-LastEquip>4 then
            LastEquip=tick()
            local eq=GetTool()
            if not eq or eq.Name:lower()=="combat" then EquipSword() end
        end
    end
end
