-- ==================== QUEST: fire every quest-like remote with the number ====================

local function FireAllQuestRemotes(qNum)
    for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
        if desc:IsA("RemoteEvent") then
            local n = desc.Name:lower()
            if n:find("quest") or n:find("accept") or n:find("start") then
                pcall(function() desc:FireServer(qNum) end)
                pcall(function() desc:FireServer(tostring(qNum)) end)
                pcall(function() desc:FireServer("Quest" .. qNum) end)
            end
        elseif desc:IsA("RemoteFunction") then
            local n = desc.Name:lower()
            if n:find("quest") or n:find("accept") or n:find("start") then
                pcall(function() desc:InvokeServer(qNum) end)
                pcall(function() desc:InvokeServer(tostring(qNum)) end)
            end
        end
    end
end

local function AcceptQuest(island)
    if not island then return end
    if tick() - LastQuestAccept < 3 then return end
    LastQuestAccept = tick()
    FireAllQuestRemotes(island.QuestNum)
end

local function AbandonQuest()
    for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
        if desc:IsA("RemoteEvent") then
            local n = desc.Name:lower()
            if n:find("abandon") or n:find("cancel") or n:find("quit") then
                pcall(function() desc:FireServer() end)
                pcall(function() desc:FireServer("repeatable") end)
            end
        end
    end
end

-- ==================== SMART QUEST DETECTION ====================
-- Watch for quest status changes in PlayerGui text labels

local function GetQuestStatusText()
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if not pg then return nil end
    for _, d in ipairs(pg:GetDescendants()) do
        if d:IsA("TextLabel") or d:IsA("TextButton") then
            local txt = d.Text or ""
            if txt:find("Quest") and (txt:find("/") or txt:find("Complete") or txt:find("complete") or txt:find("Defeat") or txt:find("Kill")) then
                return txt
            end
        end
    end
    return nil
end

local function IsQuestComplete()
    local txt = GetQuestStatusText()
    if not txt then return false end
    local lower = txt:lower()
    if lower:find("complete") or lower:find("finished") or lower:find("done") or lower:find("claim") or lower:find("return") then
        return true
    end
    local current, total = txt:match("(%d+)%s*/%s*(%d+)")
    if current and total then
        return tonumber(current) >= tonumber(total)
    end
    return false
end

local function SmartQuestCycle(island)
    if not island then return end
    AbandonQuest()
    task.wait(Jitter(0.5, 0.15))
    LastQuestAccept = 0
    AcceptQuest(island)
end

