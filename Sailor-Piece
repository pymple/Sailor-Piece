local function DetectBossIsland(bossName)
    local nf=workspace:FindFirstChild("NPCs")
    if not nf then return nil end
    local bossModel=nil
    for _,m in ipairs(nf:GetChildren()) do
        if m:IsA("Model") and m.Name==bossName then bossModel=m break end
    end
    if not bossModel then return nil end
    local br=Root(bossModel)
    if not br then return nil end
    local bossPos=br.Position
    local closestIsland,closestDist=nil,math.huge
    for _,m in ipairs(nf:GetChildren()) do
        if m:IsA("Model") and not IsBoss(m.Name) and not IsPlayer(m) then
            local r=Root(m)
            if r then
                local d=(r.Position-bossPos).Magnitude
                if d<closestDist then
                    closestDist=d
                    for _,isl in ipairs(Islands) do
                        if MatchEnemy(m.Name,isl) then closestIsland=isl.Portal break end
                    end
                end
            end
        end
    end
    return closestIsland
end
local function GetBossIsland(bossName)
    if BossIsland[bossName] then return BossIsland[bossName] end
    local detected=DetectBossIsland(bossName)
    if detected then BossIsland[bossName]=detected return detected end
    return nil
end
