local function EquipSword()
    local eq = GetEquippedTool()
    if eq and eq.Name:lower() ~= "combat" then return end
    if eq and eq.Name:lower() == "combat" then
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:UnequipTools() end
        task.wait(0.2)
    end
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if not bp then return end
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    for _, c in ipairs(bp:GetChildren()) do
        if c:IsA("Tool") and c.Name:lower() ~= "combat" then
            hum:EquipTool(c)
            return
        end
    end
end

-- ==================== MOVEMENT ====================

local function GetEnemyRoot(enemy)
    if not enemy then return nil end
    return enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Torso") or enemy:FindFirstChild("UpperTorso")
end

local function TweenAboveEnemy(enemy)
    if not enemy then return end
    local root = GetEnemyRoot(enemy)
    if not root then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local pos = root.Position
    local abovePos = Vector3.new(pos.X, pos.Y + Flags.HeightOffset, pos.Z)
    local targetCF = CFrame.new(abovePos, pos)

    local dist = (hrp.Position - abovePos).Magnitude
    if dist < 3 then
        hrp.CFrame = targetCF
        return
    end

    StopTween()
    local speed = math.max(Flags.TweenSpeed, 20)
    local duration = math.clamp(dist / speed, 0.05, 6)
    ActiveTween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCF})
    ActiveTween:Play()
    local t = tick()
    while ActiveTween and tick() - t < duration + 0.3 do task.wait(0.05) end
    ActiveTween = nil
end

-- ==================== ATTACK ====================

local function FireAbilities()
    if tick() - LastSkillTime < Flags.SkillCooldown then return end
    local any = Flags.SkillZ or Flags.SkillX or Flags.SkillC or Flags.SkillV or Flags.SkillB
    if not any then return end
    LastSkillTime = tick()
    pcall(function()
        local r = ReplicatedStorage:WaitForChild("AbilitySystem", 2):WaitForChild("Remotes", 2):WaitForChild("RequestAbility", 2)
        if Flags.SkillZ then pcall(function() r:FireServer(1) end) end
        if Flags.SkillX then pcall(function() r:FireServer(2) end) end
        if Flags.SkillC then pcall(function() r:FireServer(3) end) end
        if Flags.SkillV then pcall(function() r:FireServer(4) end) end
        if Flags.SkillB then pcall(function() r:FireServer(5) end) end
    end)
end

local function Attack(target)
    local targetRoot = target and GetEnemyRoot(target)
    pcall(function()
        ReplicatedStorage:WaitForChild("CombatSystem", 2):WaitForChild("Remotes", 2):WaitForChild("RequestHit", 2):FireServer(target)
    end)
    local tool = GetEquippedTool()
    if tool then
        pcall(function() tool:Activate() end)
        if target and targetRoot then
            local handle = tool:FindFirstChild("Handle")
            if handle then
                pcall(function()
                    firetouchinterest(handle, targetRoot, 0)
                    task.delay(0.06, function() pcall(function() firetouchinterest(handle, targetRoot, 1) end) end)
                end)
            end
        end
    end
    FireAbilities()
end

