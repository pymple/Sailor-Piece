local function DoFarmTick()
    local tgtIsland=GetFarmIsland() if not tgtIsland then return end
    if not CurIsland or CurIsland.Portal~=tgtIsland.Portal then
        if CurIsland then StopTw() QuestAbandon() task.wait(0.3) end
        CurIsland=tgtIsland IslandTPd=false SpawnDone=false QState="NONE" CurTarget=nil LockTarget=nil LockA=0 HoverPos=nil LastEnemy=0 LastQuestAccept=0 QCompDet=false
        Notify.new({Title="-> "..tgtIsland.Portal,Content="Lv."..GetLevel().." | "..tgtIsland.QuestNPC,Duration=3,Icon=ICON})
    end
    if not IslandTPd then
        if DoTP(CurIsland.Portal) then
            IslandTPd=true task.wait(1.5)
            for _=1,10 do if #FindEnemies(CurIsland)>0 then break end task.wait(0.3) end
            LastEnemy=tick()
            if F.AutoSpawn and not SpawnDone then SpawnCrystal(CurIsland) SpawnDone=true task.wait(0.3) end
            if F.AutoQuest and QState=="NONE" then task.wait(0.2) QuestAccept(CurIsland) end
        else task.wait(2) end
        return
    end
    if F.AutoQuest then
        if QState=="NONE" then if tick()-LastQuestAccept>10 then QuestAccept(CurIsland) end
        elseif QState=="ACTIVE" then if QCompDet then QState="COOLDOWN" QCompDet=false task.wait(1.0) QState="NONE" QuestAccept(CurIsland) end end
    end
    local enemies=FindEnemies(CurIsland)
    if #enemies>0 then
        LastEnemy=tick()
        if CurTarget then
            local hm=GetHum(CurTarget)
            if not hm or hm.Health<=0 or not CurTarget.Parent then if hm and hm.Health<=0 then Kills=Kills+1 end CurTarget=nil LockTarget=nil LockA=0
            elseif not MatchEnemy(CurTarget.Name,CurIsland) then CurTarget=nil LockTarget=nil LockA=0
            else local cp=ModelPos(CurTarget) if cp and DistTo(cp)>400 then CurTarget=nil LockTarget=nil LockA=0 end end
        end
        if not CurTarget then CurTarget=NearestFrom(FindEnemies(CurIsland)) end
        if CurTarget then TweenTo(CurTarget) Attack(CurTarget) end
    else
        CurTarget=nil LockTarget=nil LockA=0
        if tick()-LastEnemy>30 then IslandTPd=false SpawnDone=false QState="NONE" LastEnemy=0 QCompDet=false HoverPos=nil end
        task.wait(0.2)
    end
    if F.AutoEquip and tick()-LastEquip>4 then LastEquip=tick() local eq=GetTool() if not eq or eq.Name:lower()=="combat" then EquipSword() end end
end
local function DoBossTick()
    if not BossTargetName then
        local nextName=PickNextBossName()
        if nextName then
            BossTargetName=nextName BossTPDone=false LastBossTP=0 ClearTgt() HoverPos=nil
            Notify.new({Title="Next: "..GetBossDisplay(nextName),Content="On "..(GetBossIsland(nextName) or "?"),Duration=3,Icon=ICON})
        else ExitBossMode(nil) end
        return
    end
    if not BossTPDone then
        local bi=GetBossIsland(BossTargetName)
        if not bi then BossTargetName=nil return end
        if tick()-LastBossTP<5 then task.wait(0.5) return end
        ClearTgt() HoverPos=nil LastBossTP=tick()
        Notify.new({Title="TP -> "..bi,Content=GetBossDisplay(BossTargetName),Duration=2,Icon=ICON})
        ForceTP(bi)
        task.wait(4)
        BossTPDone=true
        for _=1,15 do
            local m=CheckBoss(BossTargetName)
            if m and ModelPos(m) then return end
            task.wait(0.5)
        end
        return
    end
    local model=CheckBoss(BossTargetName)
    if model and IsAnosModel(BossTargetName) and model.Name~=BossTargetName then BossTargetName=model.Name end
    if not model then
        local deadName=BossTargetName
        BossKills=BossKills+1 Kills=Kills+1 RecordBossDeath(deadName)
        Notify.new({Title="KILLED: "..GetBossDisplay(deadName),Content="Total: "..BossKills,Duration=4,Icon=ICON})
        BossTargetName=nil BossTPDone=false ClearTgt() HoverPos=nil task.wait(0.3)
        local nextName=PickNextBossName()
        if nextName then
            BossTargetName=nextName BossTPDone=false LastBossTP=0
            Notify.new({Title="Next: "..GetBossDisplay(nextName),Content="On "..(GetBossIsland(nextName) or "?"),Duration=3,Icon=ICON})
        else ExitBossMode(deadName) end
        return
    end
    local bossP=ModelPos(model)
    if not bossP then
        BossTPDone=false
        task.wait(1)
        return
    end
    CurTarget=model
    TweenTo(model)
    Attack(model)
    if F.AutoEquip and tick()-LastEquip>4 then LastEquip=tick() local eq=GetTool() if not eq or eq.Name:lower()=="combat" then EquipSword() end end
end
