-- ==================== MAIN LOOP ====================

task.spawn(function()
    while ClockRunning do
        if not Flags.AutoFarmLevel then task.wait(0.5) continue end

        -- Death recovery
        if not IsCharacterAlive() then
            StopTween()
            CurrentTarget = nil
            LockedAboveTarget = nil
            LockAlpha = 0
            WaitForCharacter()
            task.wait(0.5)
            if Flags.AutoEquip then EquipSword() task.wait(0.3) end
        end
        if not IsCharacterAlive() then task.wait(0.5) continue end

        -- ==================== BOSS PRIORITY ====================
        if Flags.BossEnabled and not FightingBoss then
            local nextBoss = GetNextBoss()
            if nextBoss then
                -- Boss found! Save current state and switch
                SaveFarmState()
                FightingBoss = true
                CurrentBossTarget = nextBoss
                CurrentTarget = nil
                LockedAboveTarget = nil
                LockAlpha = 0
                StopTween()
                Notifier.new({
                    Title = "⚔ BOSS: " .. nextBoss.Name,
                    Content = "On " .. BossToIsland[nextBoss.Name] .. " | Interrupting farm",
                    Duration = 4, Icon = AVATAR_ICON
                })
            end
        end

        if FightingBoss then
            -- Validate boss still alive
            if CurrentBossTarget then
                local hum = CurrentBossTarget:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health <= 0 or not CurrentBossTarget.Parent then
                    -- This boss is dead
                    BossKillCount = BossKillCount + 1
                    KillCount = KillCount + 1
                    Notifier.new({
                        Title = "⚔ BOSS KILLED: " .. CurrentBossTarget.Name,
                        Content = "Total Boss Kills: " .. BossKillCount,
                        Duration = 4, Icon = AVATAR_ICON
                    })
                    CurrentBossTarget = nil
                    CurrentTarget = nil
                    LockedAboveTarget = nil
                    LockAlpha = 0
                    StopTween()

                    -- Check for more bosses
                    task.wait(0.5)
                    local nextBoss = GetNextBoss()
                    if nextBoss then
                        CurrentBossTarget = nextBoss
                        Notifier.new({
                            Title = "⚔ Next Boss: " .. nextBoss.Name,
                            Content = "On " .. BossToIsland[nextBoss.Name],
                            Duration = 3, Icon = AVATAR_ICON
                        })
                    else
                        -- All bosses dead, resume farming
                        Notifier.new({
                            Title = "⚔ All Bosses Clear!",
                            Content = "Resuming farming...",
                            Duration = 3, Icon = AVATAR_ICON
                        })
                        RestoreFarmState()
                        task.wait(0.3)
                        continue
                    end
                end
            end

            if not CurrentBossTarget then
                -- No boss target but still in boss mode? Exit
                RestoreFarmState()
                task.wait(0.3)
                continue
            end

            -- Check distance to boss — do we need to teleport?
            local bossRoot = GetEnemyRoot(CurrentBossTarget)
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local bossIsland = BossToIsland[CurrentBossTarget.Name]

            if bossRoot and hrp then
                local distToBoss = (hrp.Position - bossRoot.Position).Magnitude

                if distToBoss > 500 and bossIsland then
                    -- Need to teleport to boss island
                    StopTween()
                    LockedAboveTarget = nil
                    LockAlpha = 0
                    if TeleportToIsland(bossIsland) then
                        task.wait(2)
                        -- Wait for boss to be reachable
                        for _ = 1, 15 do
                            bossRoot = GetEnemyRoot(CurrentBossTarget)
                            if bossRoot and hrp and (hrp.Position - bossRoot.Position).Magnitude < 500 then break end
                            task.wait(0.3)
                        end
                    else
                        task.wait(2)
                        continue
                    end
                end

                -- Fight the boss
                CurrentTarget = CurrentBossTarget
                TweenAboveEnemy(CurrentBossTarget)
                Attack(CurrentBossTarget)
            else
                -- Can't find boss root, try teleporting
                if bossIsland then
                    TeleportToIsland(bossIsland)
                    task.wait(2)
                end
            end

            -- Equip check during boss
            if Flags.AutoEquip and tick() - LastEquipCheck > 4 then
                LastEquipCheck = tick()
                local eq = GetEquippedTool()
                if not eq or eq.Name:lower() == "combat" then EquipSword() end
            end

            task.wait(0.12)
            continue
        end

        -- ==================== NORMAL FARMING ====================

        local playerLevel = GetPlayerLevel()
        if playerLevel == 0 then task.wait(0.5) continue end

        local targetIsland
        if Flags.SelectedIsland == "Auto" then
            targetIsland = GetIslandForLevel(playerLevel)
        else
            targetIsland = GetIslandByName(Flags.SelectedIsland) or GetIslandForLevel(playerLevel)
        end

        -- Island changed
        if not CurrentIsland or CurrentIsland.Portal ~= targetIsland.Portal then
            if CurrentIsland then
                StopTween()
                FireQuestAbandon()
                task.wait(0.5)
            end
            CurrentIsland = targetIsland
            IslandTeleported = false
            QuestState = "NONE"
            CurrentTarget = nil
            LockedAboveTarget = nil
            LockAlpha = 0
            LastEnemySeenTime = 0
            LastQuestAcceptTime = 0
            QuestCompletedDetected = false
            Notifier.new({Title = "-> "..targetIsland.Portal, Content = "Lv."..playerLevel.." | "..targetIsland.QuestNPC, Duration = 3, Icon = AVATAR_ICON})
        end

        -- Teleport to island if needed
        if not IslandTeleported then
            if TeleportToIsland(CurrentIsland.Portal) then
                IslandTeleported = true
                task.wait(1.5)
                -- Wait for enemies to load
                for _ = 1, 10 do
                    if #FindEnemies(CurrentIsland) > 0 then break end
                    task.wait(0.3)
                end
                LastEnemySeenTime = tick()
                if Flags.AutoSpawn then InteractSpawnCrystal(CurrentIsland) end
                if Flags.AutoQuest and QuestState == "NONE" then
                    task.wait(0.3)
                    FireQuestAccept(CurrentIsland)
                end
            else
                task.wait(2)
            end
            continue
        end

        -- Quest state machine (only fires when appropriate)
        if Flags.AutoQuest then
            if QuestState == "NONE" then
                if tick() - LastQuestAcceptTime > 10 then
                    FireQuestAccept(CurrentIsland)
                end
            elseif QuestState == "ACTIVE" then
                if QuestCompletedDetected then
                    QuestState = "COOLDOWN"
                    QuestCompletedDetected = false
                    task.wait(1.0)
                    FireQuestAccept(CurrentIsland)
                end
            end
        end

        -- Find and fight enemies (STRICT island match)
        local enemies = FindEnemies(CurrentIsland)
        if #enemies > 0 then
            LastEnemySeenTime = tick()

            -- Validate current target
            if CurrentTarget then
                local hum = CurrentTarget:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health <= 0 or not CurrentTarget.Parent then
                    if hum and hum.Health <= 0 then KillCount = KillCount + 1 end
                    CurrentTarget = nil
                    LockedAboveTarget = nil
                    LockAlpha = 0
                elseif not MatchesEnemyName(CurrentTarget.Name, CurrentIsland) then
                    CurrentTarget = nil
                    LockedAboveTarget = nil
                    LockAlpha = 0
                end
            end

            if not CurrentTarget then
                CurrentTarget = GetNearest(enemies)
            end

            if CurrentTarget then
                TweenAboveEnemy(CurrentTarget)
                Attack(CurrentTarget)
            end
        else
            CurrentTarget = nil
            LockedAboveTarget = nil
            LockAlpha = 0
            if tick() - LastEnemySeenTime > 30 then
                IslandTeleported = false
                QuestState = "NONE"
                LastEnemySeenTime = 0
                QuestCompletedDetected = false
            end
            task.wait(0.2)
        end

        -- Auto equip
        if Flags.AutoEquip and tick() - LastEquipCheck > 4 then
            LastEquipCheck = tick()
            local eq = GetEquippedTool()
            if not eq or eq.Name:lower() == "combat" then EquipSword() end
        end

        task.wait(0.12)
    end
end)
