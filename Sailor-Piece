local function Jitter(base, variance)
    return base + (math.random() * variance * 2 - variance)
end

local function StopTween()
    if ActiveTween then
        pcall(function() ActiveTween:Cancel() end)
        ActiveTween = nil
    end
end

local function TweenTo(targetCFrame, callback)
    StopTween()
    local char = LocalPlayer.Character
    if not char then if callback then callback() end return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then if callback then callback() end return end

    local dist = (hrp.Position - targetCFrame.Position).Magnitude
    if dist < 2 then
        hrp.CFrame = targetCFrame
        if callback then callback() end
        return
    end

    local speed = math.max(Flags.TweenSpeed, 20)
    local duration = dist / speed
    duration = math.clamp(duration, 0.08, 8)

    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    ActiveTween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
    ActiveTween.Completed:Connect(function()
        ActiveTween = nil
        if callback then callback() end
    end)
    ActiveTween:Play()
end

local function TweenToAndWait(targetCFrame)
    local done = false
    TweenTo(targetCFrame, function() done = true end)
    local timeout = tick()
    while not done and tick() - timeout < 10 do
        task.wait(0.05)
    end
end

