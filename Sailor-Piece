            local goalPos=Vector3.new(pos.X,pos.Y+F.HeightOffset,pos.Z)
            local goalCF=CFrame.new(goalPos,pos)
            LockA=math.min(LockA+dt*3,1)
            hrp.CFrame=hrp.CFrame:Lerp(goalCF,LockA*0.85)
            HoverPos=goalPos
        end
    elseif HoverPos then
        local hoverCF=CFrame.new(HoverPos,HoverPos+Vector3.new(0,-1,0))
        hrp.CFrame=hrp.CFrame:Lerp(hoverCF,0.5)
    end
