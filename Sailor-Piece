end

local function EquipSword()
    local eq = GetEquippedTool()
    if eq and eq.Name:lower() ~= "combat" then return end
    if eq and eq.Name:lower() == "combat" then
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:UnequipTools() end
        task.wait(Jitter(0.25, 0.1))
    end
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if not bp then return end
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    for _, c in ipairs(bp:GetChildren()) do
        if c:IsA("Tool") and c.Name:lower() ~= "combat" then
            hum:EquipTool(c)
            return
        end
    end
end

local function GetEnemyRoot(enemy)
    if not enemy then return nil end
    return enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Torso") or enemy:FindFirstChild("UpperTorso")
end

local function GetBehindCFrame(enemy)
    if not enemy then return nil end
    local root = GetEnemyRoot(enemy)
    if not root then return nil end
    local enemyCF = root.CFrame
    local behindPos = enemyCF.Position - enemyCF.LookVector * Flags.BehindOffset
    behindPos = behindPos + Vector3.new(Jitter(0, 0.6), 0, Jitter(0, 0.6))
    local lookAt = Vector3.new(root.Position.X, behindPos.Y, root.Position.Z)
    return CFrame.new(behindPos, lookAt)
end

local function IsCloseEnough(targetPos, maxDist)
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    return (hrp.Position - targetPos).Magnitude <= maxDist
end

local function MoveToTarget(enemy)
    if not enemy then return end
    local root = GetEnemyRoot(enemy)
    if not root then return end
    local behindCF = GetBehindCFrame(enemy)
    if not behindCF then return end
    TweenToAndWait(behindCF)
end

local function Attack(target)
    local targetRoot = target and GetEnemyRoot(target)
    pcall(function()
        local remotes = ReplicatedStorage:WaitForChild("CombatSystem", 2):WaitForChild("Remotes", 2)
        local requestHit = remotes:WaitForChild("RequestHit", 2)
        requestHit:FireServer(target)
    end)

    local tool = GetEquippedTool()
    if tool then
        pcall(function() tool:Activate() end)
        if target and targetRoot then
            local handle = tool:FindFirstChild("Handle")
            if handle then
                pcall(function()
                    firetouchinterest(handle, targetRoot, 0)
                    task.delay(Jitter(0.06, 0.02), function()
                        pcall(function() firetouchinterest(handle, targetRoot, 1) end)
                    end)
                end)
                task.wait(Jitter(0.04, 0.02))
                local backup = target:FindFirstChild("Torso") or target:FindFirstChild("UpperTorso")
                if backup and backup ~= targetRoot then
                    pcall(function()
                        firetouchinterest(handle, backup, 0)
                        task.delay(Jitter(0.06, 0.02), function()
                            pcall(function() firetouchinterest(handle, backup, 1) end)
                        end)
                    end)
                end
            end
        end
    end
end

