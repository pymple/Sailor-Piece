local function ScanAllBossTimers()
    CacheBossPositions()
    local results={}
    local nf=GetNPCFolder()
    if nf then
        for _,bDef in ipairs(Bosses) do
            for _,m in ipairs(nf:GetChildren()) do
                if m:IsA("Model") and m.Name==bDef.Name then
                    local hm=GetHum(m)
                    if hm and hm.Health>0 then results[bDef.Name]={alive=true}
                    else
                        for _,d in ipairs(m:GetDescendants()) do if d:IsA("TextLabel") then local mn,sc=(d.Text or ""):match("(%d+):(%d+)") if mn and sc then results[bDef.Name]={m=tonumber(mn),s=tonumber(sc)} break end end end
                        if not results[bDef.Name] then for _,d in ipairs(m:GetDescendants()) do if d:IsA("BillboardGui") then for _,child in ipairs(d:GetDescendants()) do if child:IsA("TextLabel") then local mn,sc=(child.Text or ""):match("(%d+):(%d+)") if mn and sc then results[bDef.Name]={m=tonumber(mn),s=tonumber(sc)} break end end end if results[bDef.Name] then break end end end end
                    end
                    break
                end
            end
        end
    end
    local pg=LP:FindFirstChild("PlayerGui")
    if pg then for _,desc in ipairs(pg:GetDescendants()) do if desc:IsA("TextLabel") then local txt=desc.Text or "" for _,bDef in ipairs(Bosses) do if not results[bDef.Name] then if txt:find(bDef.Display) then local mn,sc=txt:match("(%d+):(%d+)") if mn and sc then results[bDef.Name]={m=tonumber(mn),s=tonumber(sc)} end end end end end end end
    local anosModel=FindAnyAnosAlive()
    if anosModel then results["Anos"]={alive=true,modelName=anosModel.Name} end
    for k,v in pairs(results) do BossTimerCache[k]=v BossTimerCache[k].t=tick() end
    return results
end
local function GetBossTimerText()
    local lines={}
    for _,bDef in ipairs(Bosses) do
        local info=BossTimerCache[bDef.Name]
        local status=""
        if info and(tick()-(info.t or 0))<5 then
            if info.alive then status="ALIVE"
            elseif info.m and info.s then local total=info.m*60+info.s if total==0 then status="ALIVE" elseif total<=15 then status=info.m..":"..string.format("%02d",info.s).." SPAWNING!" else status=info.m..":"..string.format("%02d",info.s) end
            else status="Loading..." end
        else local dt=BossDeathTimes[bDef.Name] if dt then local remain=math.max(0,300-(tick()-dt)) if remain>0 then local mn=math.floor(remain/60) local sc=math.floor(remain%60) status=mn..":"..string.format("%02d",sc) else status="Ready!" end else status="Loading..." end end
        table.insert(lines,bDef.Display.." ("..bDef.Island..") - "..status)
    end
    local anosInfo=BossTimerCache["Anos"]
    if anosInfo and anosInfo.alive and(tick()-(anosInfo.t or 0))<5 then
        local diff=anosInfo.modelName and anosInfo.modelName:match("AnosBoss_(.+)") or "?"
        table.insert(lines,"Anos "..diff.." ("..ANOS_ISLAND..") - ALIVE")
    elseif F.AnosEnabled then
        table.insert(lines,"Anos ("..ANOS_ISLAND..") - Not Spawned")
    end
    return table.concat(lines,"\n")
end
