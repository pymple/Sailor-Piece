        if not hm or hm.Health<=0 or not LockTarget.Parent then
            HoverPos=hrp.Position
            LockTarget=nil
            LockA=0
        else
            if not BossFight and CurIsland then
                if not Util.MatchEnemy(LockTarget.Name,CurIsland) and not Util.IsBoss(LockTarget.Name) then
                    HoverPos=hrp.Position
                    LockTarget=nil
                    LockA=0
                end
            end
        end
    end
    if LockTarget then
        local r=Util.Root(LockTarget)
        if r then
            local pos=r.Position
            local goalPos=Vector3.new(pos.X,pos.Y+F.HeightOffset,pos.Z)
            local goalCF=CFrame.new(goalPos,pos)
            LockA=math.min(LockA+dt*3,1)
            hrp.CFrame=hrp.CFrame:Lerp(goalCF,LockA*0.85)
            HoverPos=goalPos
        end
    elseif HoverPos then
        local hoverCF=CFrame.new(HoverPos,HoverPos+Vector3.new(0,-1,0))
        hrp.CFrame=hrp.CFrame:Lerp(hoverCF,0.5)
    end
    hrp.Velocity=Vector3.zero
    pcall(function() hrp.AssemblyLinearVelocity=Vector3.zero end)
    pcall(function() hrp.AssemblyAngularVelocity=Vector3.zero end)
end))
