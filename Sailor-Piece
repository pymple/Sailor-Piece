local function TweenTo(enemy)
    if not enemy then return end
    local pos=ModelPos(enemy) if not pos then return end
    local hrp=PlayerHRP() if not hrp then return end
    if TweenTarget~=enemy then StopTw() end
    local ap=Vector3.new(pos.X,pos.Y+F.HeightOffset,pos.Z)
    local d=(hrp.Position-ap).Magnitude
    if d<5 then LockTarget=enemy TweenOn=false TweenTarget=nil HoverPos=ap return end
    if TweenOn and TweenTarget==enemy then return end
    StopTw() TweenOn=true TweenTarget=enemy LockTarget=nil LockA=0
    local cf=CFrame.new(ap,pos)
    local dur=math.clamp(d/math.max(F.TweenSpeed,20),0.05,8)
    ATween=TweenService:Create(hrp,TweenInfo.new(dur,Enum.EasingStyle.Linear),{CFrame=cf})
    ATween.Completed:Connect(function() ATween=nil TweenOn=false TweenTarget=nil LockTarget=enemy HoverPos=ap end)
    ATween:Play()
    local t=tick()
    while TweenOn and TweenTarget==enemy and tick()-t<dur+0.5 do task.wait(0.05) end
end
