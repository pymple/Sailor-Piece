        end
        if not CurTarget then CurTarget=NearestFrom(FindEnemies(CurIsland)) end
        if CurTarget then TweenTo(CurTarget) Attack(CurTarget) end
    else
        CurTarget=nil LockTarget=nil
        if tick()-LastEnemy>20 then IslandTPd=false SpawnDone=false QState="NONE" LastEnemy=0 QCompDet=false HoverPos=nil end
        task.wait(0.15)
