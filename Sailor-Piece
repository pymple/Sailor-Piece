AddConnection(UserInputService.InputBegan:Connect(function(input, gp)
    if gp or IsTyping() then return end
    if input.KeyCode == Enum.KeyCode.V then
        ToggleAutoFarmLevel()
    elseif input.KeyCode == Enum.KeyCode.B then
        CachedEnemies = {}
        CacheTime = 0
        local enemies = FindEnemies(CurrentIsland)
        local nearest = GetNearest(enemies)
        if nearest then
            MoveToTarget(nearest)
            Attack(nearest)
        end
    end
end))

SetupAntiAFK()

local IslandTeleported = false
local QuestAccepted = false
local IslandLoadTimer = 0

task.spawn(function()
    while ClockRunning do
        if Flags.AutoFarmLevel then
            local playerLevel = GetPlayerLevel()

            if playerLevel == 0 then
                task.wait(1)
                continue
            end

            local targetIsland
            if Flags.SelectedIsland == "Auto" then
                targetIsland = GetIslandForLevel(playerLevel)
            else
                targetIsland = GetIslandByName(Flags.SelectedIsland) or GetIslandForLevel(playerLevel)
            end

            if not CurrentIsland or CurrentIsland.Portal ~= targetIsland.Portal then
                if CurrentIsland then
                    StopTween()
                    AbandonQuest()
                    task.wait(Jitter(0.5, 0.15))
                end
                CurrentIsland = targetIsland
                IslandTeleported = false
                QuestAccepted = false
                CurrentTarget = nil
                CachedEnemies = {}
                CacheTime = 0
                QuestKillCount = 0
                LastQuestReaccept = 0
                LastEnemySeenTime = 0
                Notifier.new({
                    Title = "-> "..targetIsland.Portal,
                    Content = "Lv."..playerLevel.." | Farm until Lv."..targetIsland.FarmUntil,
                    Duration = 4,
                    Icon = AVATAR_ICON
                })
            end

            if not IslandTeleported then
                if CanTeleport() then
                    local didTP = TeleportToIsland(CurrentIsland.Portal)
                    if didTP then
                        IslandTeleported = true
                        IslandLoadTimer = tick()
                        task.wait(2)
                        local enemies = WaitForEnemies(CurrentIsland, 8)
                        if #enemies > 0 then
                            LastEnemySeenTime = tick()
                        end
                        if Flags.AutoQuest and CurrentIsland.Quest and not QuestAccepted then
                            task.wait(Jitter(0.3, 0.1))
                            AcceptQuests(CurrentIsland.Quest)
                            QuestAccepted = true
                            QuestKillCount = 0
                            LastQuestReaccept = tick()
                        end
                    else
                        task.wait(5)
                    end
                else
                    task.wait(5)
                end
                continue
            end

            if not QuestAccepted and Flags.AutoQuest and CurrentIsland.Quest then
                AcceptQuests(CurrentIsland.Quest)
                QuestAccepted = true
                QuestKillCount = 0
                LastQuestReaccept = tick()
            end

            CachedEnemies = {}
            CacheTime = 0
            local enemies = FindEnemies(CurrentIsland)

            if #enemies > 0 then
                LastEnemySeenTime = tick()
                local nearest = GetNearest(enemies)
                if nearest then
                    CurrentTarget = nearest
                    MoveToTarget(nearest)

                    local root = GetEnemyRoot(nearest)
                    local hum = nearest:FindFirstChildOfClass("Humanoid")
                    if root and hum and hum.Health > 0 and IsCloseEnough(root.Position, 15) then
                        Attack(nearest)

                        if hum.Health <= 0 then
                            KillCount = KillCount + 1
                            QuestKillCount = QuestKillCount + 1
                            CurrentTarget = nil
                            task.wait(Jitter(0.3, 0.1))

                            if Flags.AutoQuest and QuestKillCount >= QuestKillGoal then
                                task.wait(Jitter(0.5, 0.2))
                                SmartQuestCycle()
                            end
                        end
                    end
                end
            else
                if LastEnemySeenTime > 0 and tick() - LastEnemySeenTime > 60 and CanTeleport() then
                    IslandTeleported = false
                    QuestAccepted = false
                    LastEnemySeenTime = 0
                end
                task.wait(0.5)
            end

            if Flags.AutoEquip and tick() - LastEquipCheck > Jitter(4, 1) then
                LastEquipCheck = tick()
                local eq = GetEquippedTool()
                if not eq or eq.Name:lower() == "combat" then EquipSword() end
            end

            if Flags.AutoQuest and CurrentIsland.Quest and tick() - LastQuestReaccept > 25 and tick() - LastQuestTime > 10 then
                SmartQuestCycle()
            end

            task.wait(Jitter(Flags.SwingSpeed, 0.06))
        else
            task.wait(0.5)
        end
    end
end)
