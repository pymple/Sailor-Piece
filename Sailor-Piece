local Chest={}
function Chest.FindRemote()
    if ChestRemote then return ChestRemote end
    if ChestRemoteSearched then return nil end
    for _,desc in ipairs(RS:GetDescendants()) do
        if desc:IsA("RemoteEvent") or desc:IsA("RemoteFunction") then
            local n=desc.Name:lower()
            if n=="openchest" or n=="usechest" or n=="chestopen" or n=="useitem" or n=="openitem" then
                ChestRemote=desc
                ChestRemoteSearched=true
                return desc
            end
        end
    end
    for _,desc in ipairs(RS:GetDescendants()) do
        if desc:IsA("RemoteEvent") or desc:IsA("RemoteFunction") then
            local n=desc.Name:lower()
            if n:find("chest") or(n:find("use") and n:find("item")) or n:find("open") then
                local fp=desc:GetFullName():lower()
                if not fp:find("shop") and not fp:find("buy") and not fp:find("equip") then
                    ChestRemote=desc
                    ChestRemoteSearched=true
                    return desc
                end
            end
        end
    end
    ChestRemoteSearched=true
    return nil
end
function Chest.Open()
    if not F.AutoChest then return end
    if tick()-LastChest<2 then return end
    LastChest=tick()
    local remote=Chest.FindRemote()
    if remote then
        local args={
            {"Common Chest"},{"Rare Chest"},{"Epic Chest"},{"Mythical Chest"},
            {"Use","Common Chest"},{"Use","Rare Chest"},{"Use","Epic Chest"},{"Use","Mythical Chest"},
            {"Use","Common Chest",1,false},{"Use","Rare Chest",1,false},{"Use","Epic Chest",1,false},{"Use","Mythical Chest",1,false},
            {"Open","Common Chest"},{"Open","Rare Chest"},{"Open","Epic Chest"},{"Open","Mythical Chest"},
            {"CommonChest"},{"RareChest"},{"EpicChest"},{"MythicalChest"},
        }
        for _,a in ipairs(args) do
            if remote:IsA("RemoteEvent") then
                pcall(function() remote:FireServer(unpack(a)) end)
            elseif remote:IsA("RemoteFunction") then
                pcall(function() remote:InvokeServer(unpack(a)) end)
            end
        end
        return
    end
    local bp=LP:FindFirstChild("Backpack")
    if bp then
        for _,item in ipairs(bp:GetChildren()) do
            if item:IsA("Tool") then
                local ln=item.Name:lower()
                if ln:find("chest") then
                    local hm=LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
                    if hm then
                        hm:EquipTool(item)
                        task.wait(0.2)
                        pcall(function() item:Activate() end)
                        task.wait(0.2)
                        hm:UnequipTools()
                        task.wait(0.2)
                    end
                end
            end
        end
    end
    local pg=LP:FindFirstChild("PlayerGui")
    if pg then
        for _,desc in ipairs(pg:GetDescendants()) do
            if desc:IsA("TextButton") or desc:IsA("ImageButton") then
                local bn=(desc.Name or ""):lower()
                local bt=""
                pcall(function() bt=(desc.Text or ""):lower() end)
                if bn:find("chest") or bt:find("open") and bt:find("chest") then
                    pcall(function() fireclick(desc) end)
                    pcall(function()
                        for _,conn in ipairs(desc:GetConnections("Activated")) do conn:Fire() end
                    end)
                end
            end
        end
    end
end
