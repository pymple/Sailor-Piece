fn.FireSummonBoss=function(name)
    if not S.BSF[name] then return end
    pcall(function()
        if name=="AnosBoss" then
            local r=fn.WalkPathWait(RS,2,unpack(R.AnosBoss))
            if not r then return end
            local diff=fn.GetSummonBossDiff(name) or "Normal"
            r:FireServer("Anos",diff)
        else
            local r=fn.WalkPathWait(RS,2,unpack(R.SummonBoss))
            if not r then return end
            local diff=fn.GetSummonBossDiff(name)
            if diff then r:FireServer(name,diff) else r:FireServer(name) end
