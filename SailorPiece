fn.GetGoalForEnemy=function(enemy)
    local pos=fn.ModelPos(enemy) if not pos then return nil,nil end
    if F.FarmMode=="Behind" then
        local ecf=fn.ModelCF(enemy)
        if ecf then
            local behind=ecf.Position-ecf.LookVector*F.OffsetDist
            return Vector3.new(behind.X,behind.Y+1,behind.Z),ecf.Position
        end
        return Vector3.new(pos.X,pos.Y+1,pos.Z),pos
    end
    return Vector3.new(pos.X,pos.Y+F.HeightOffset,pos.Z),pos
end
fn.TweenTo=function(enemy)
    if not enemy then return end
    local goal,look=fn.GetGoalForEnemy(enemy) if not goal then return end
    local hrp=fn.PlayerHRP() if not hrp then return end
    local d=(hrp.Position-goal).Magnitude
    if d>400 then return end
    if F.MoveMode=="Teleport" then
        fn.StopTw()
        hrp.CFrame=CFrame.new(goal,look or goal)
        S.LockTarget=enemy S.TweenOn=false S.TweenTarget=nil S.HoverPos=goal
        return
    end
    if S.TweenTarget~=enemy then fn.StopTw() end
    d=(hrp.Position-goal).Magnitude
    if d<5 then S.LockTarget=enemy S.TweenOn=false S.TweenTarget=nil S.HoverPos=goal return end
    if S.TweenOn and S.TweenTarget==enemy then return end
    fn.StopTw() S.TweenOn=true S.TweenTarget=enemy S.LockTarget=nil
    local cf=CFrame.new(goal,look or goal)
    local dur=math.clamp(d/math.max(F.TweenSpeed,20),0.05,8)
    S.ATween=TweenService:Create(hrp,TweenInfo.new(dur,Enum.EasingStyle.Linear),{CFrame=cf})
    S.ATweenConn=S.ATween.Completed:Connect(function() S.ATween=nil S.ATweenConn=nil S.TweenOn=false S.TweenTarget=nil S.LockTarget=enemy S.HoverPos=goal end)
    S.ATween:Play()
    local t=tick()
    while S.TweenOn and S.TweenTarget==enemy and tick()-t<dur+0.5 do task.wait(0.05) end
end
fn.TweenToPoint=function(goal)
    local hrp=fn.PlayerHRP() if not hrp then return end
    if F.MoveMode=="Teleport" then
        fn.StopTw()
        hrp.CFrame=CFrame.new(goal,goal+Vector3.new(0,-1,0))
        S.HoverPos=goal
        return
    end
    local d=(hrp.Position-goal).Magnitude
    if d<5 then return end
    fn.StopTw() S.TweenOn=true S.LockTarget=nil
    local cf=CFrame.new(goal,goal+Vector3.new(0,-1,0))
    local dur=math.clamp(d/math.max(F.TweenSpeed,20),0.05,8)
    S.ATween=TweenService:Create(hrp,TweenInfo.new(dur,Enum.EasingStyle.Linear),{CFrame=cf})
    S.ATweenConn=S.ATween.Completed:Connect(function() S.ATween=nil S.ATweenConn=nil S.TweenOn=false S.HoverPos=goal end)
    S.ATween:Play()
    local t=tick()
    while S.TweenOn and tick()-t<dur+0.5 do task.wait(0.05) end
end
