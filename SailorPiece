UISec:AddColorPicker({Name="Highlight",Default=S.Hub.Colors.Highlight,Callback=function(v) S.Hub.Colors.Highlight=v fn.RefreshButtonBorders(fn.BrightenColor(v)) S.Hub:RefreshCurrentColor() end})
UISec:AddColorPicker({Name="Toggle Color",Default=S.Hub.Colors.Toggle,Callback=function(v) S.Hub.Colors.Toggle=v fn.RefreshButtonBorders(fn.BrightenColor(v)) S.Hub:RefreshCurrentColor() end})
UISec:AddColorPicker({Name="Drop Color",Default=S.Hub.Colors.DropColor,Callback=function(v) S.Hub.Colors.DropColor=v S.Hub:RefreshCurrentColor() end})
UISec:AddColorPicker({Name="Block Color",Default=S.Hub.Colors.BlockColor,Callback=function(v) S.Hub.Colors.BlockColor=v S.Hub:RefreshCurrentColor() end})
UISec:AddColorPicker({Name="Background Color",Default=S.Hub.Colors.BGDBColor,Callback=function(v) S.Hub.Colors.BGDBColor=v S.Hub:RefreshCurrentColor() end})
UISec:AddColorPicker({Name="Stroke Color",Default=S.Hub.Colors.StrokeColor,Callback=function(v) S.Hub.Colors.StrokeColor=v S.Hub:RefreshCurrentColor() end})
UISec:AddButton({Name="Copy Discord",Callback=function() pcall(function() setclipboard(S.DISCORD) end) S.Notify.new({Title="Copied",Content="Discord link copied!",Duration=2,Icon=S.ICON}) end})
UISec:AddButton({Name="Destroy GUI",Callback=function()
    S.Running=false
    pcall(function() local c=LP.Character if c then local hm=c:FindFirstChildOfClass("Humanoid") if hm then hm.PlatformStand=false end end end)
    for _,c in ipairs(S.Conns) do pcall(function() c:Disconnect() end) end
    task.delay(0.15,function() pcall(function() S.Win:Destroy() end) end)
end})
local InfoSec=SetTab:DrawSection({Name="Info",Position="right"})
InfoSec:AddParagraph({Title="pimpleHUB v7.5",Content="Left Alt = Toggle UI | V = Farm | B = Boss\nN = Summon | M = All Skills\nFarm Style: Plank (above) or Behind (offset)\nMove Mode: Tween (smooth) or Teleport (instant)\nBoss: Portal TP first, cached positions\nAnos: separate summon remote, detects any difficulty\nChest: batch open all at once"})
local ThSec=ThTab:DrawSection({Name="UI Themes",Position="left"})
ThSec:AddDropdown({Name="Select Theme",Default="Default",Values={"Default","Dark Green","Dark Blue","Purple Rose","Skeet"},Callback=function(v) S.Hub:SetTheme(v) end})
local CfgUI=S.Win:DrawConfig({Name="Config",Icon="folder",Config=S.CfgMgr})
CfgUI:Init()
task.defer(function()
    pcall(function()
        local hubGui
        for _,ch in ipairs(LP.PlayerGui:GetChildren()) do if ch:IsA("ScreenGui") and ch.Name:find("PIMPLE") then hubGui=ch break end end
        if not hubGui then return end
        local bc=fn.BrightenColor(S.Hub.Colors.Toggle)
        for _,d in ipairs(hubGui:GetDescendants()) do
            if (d:IsA("TextButton") or d:IsA("ImageButton") or d:IsA("Frame")) and d:FindFirstChildOfClass("UICorner") then
                local s=d:FindFirstChildOfClass("UIStroke")
                if not s then s=Instance.new("UIStroke") s.ApplyStrokeMode=Enum.ApplyStrokeMode.Border s.Parent=d end
                s.Thickness=2 s.Color=bc
                table.insert(S.ButtonBorderStrokes,s)
            end
        end
    end)
end)
fn.Conn(UserInputService.InputBegan:Connect(function(input,gp) if gp or fn.Typing() then return end if input.KeyCode==Enum.KeyCode.V then fn.ToggleFarm() elseif input.KeyCode==Enum.KeyCode.B then fn.ToggleBoss() elseif input.KeyCode==Enum.KeyCode.N then fn.ToggleSummonBoss() elseif input.KeyCode==Enum.KeyCode.M then fn.ToggleAllSkills() end end))
end -- UI do block
---------- STARTUP ----------
fn.SetupAntiAFK()
task.spawn(fn.DisableGameAutoSkills)
task.spawn(function() while S.Running do if F.AutoQuest then fn.QuestCompletionScan() end task.wait(2) end end)
task.spawn(function() while S.Running do if F.AutoChest then fn.OpenAllChests() end if F.AutoMerchant then fn.BuyMerchantItems() end task.wait(8) end end)
task.spawn(function()
    while S.Running do
        repeat
            local isSummonActive=F.SummonBossEnabled and fn.HasAnySummonBossEnabled()
            if not F.AutoFarmLevel and not isSummonActive then task.wait(0.3) break end
            if not fn.IsAlive() then
                fn.ClearTgt() S.HoverPos=nil fn.WaitChar() task.wait(0.3)
                if F.AutoEquip then fn.EquipSword() task.wait(0.2) end
                if not S.BossFight and not S.SummonBossFight then S.IslandTPd=false S.SpawnDone=false end
                S.LastBossTP=0 S.BossTPDone=false S.LastSummonBossTP=0 S.SummonBossTPDone=false
            end
            if not fn.IsAlive() then task.wait(0.3) break end
            if not isSummonActive and S.SummonBossFight then fn.ExitSummonBossMode() end
            if isSummonActive and not S.SummonBossFight then
                S.SummonBossFight=true S.BossFight=false S.BossTargetName=nil S.BossTPDone=false S.SummonBossTPDone=false S.LastSummonBossTP=0 S.SummonBossCurrentIsland=nil S.SummonBossOrder=0 S.SummonBossFailCount={} S.SummonBossFireTime={} fn.ClearTgt() S.HoverPos=nil S.CurIsland=nil S.IslandTPd=false
                S.Notify.new({Title="Summon Boss Mode",Content="Starting summon boss cycle",Duration=3,Icon=S.ICON})
            end
            if S.SummonBossFight then fn.DoSummonBossTick() task.wait(0.1) break end
            if not F.AutoFarmLevel then task.wait(0.3) break end
            if F.BossEnabled and not S.BossFight then
                local nextName=fn.PickNextBossName()
                if nextName then
                    S.BossFight=true S.BossTargetName=nextName S.BossTPDone=false S.LastBossTP=0 S.BossCurrentIsland=fn.GetBossIsland(nextName) fn.ClearTgt() S.HoverPos=nil S.CurIsland=nil S.IslandTPd=false
                    S.Notify.new({Title="BOSS: "..fn.GetBossDisplay(nextName),Content="On "..(S.BossCurrentIsland or "?").." | Stopping farm",Duration=4,Icon=S.ICON})
                end
            end
            if S.BossFight then fn.DoBossTick() task.wait(0.1) break end
            fn.DoFarmTick()
            task.wait(0.1)
        until true
    end
end)
